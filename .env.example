# Supabase Postgres — pooled connection (PgBouncer, port 6543) for app runtime
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase Postgres — direct connection (port 5432) for drizzle-kit migrations
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Strava OAuth app — create at https://www.strava.com/settings/api
# Authorization Callback Domain: localhost (for dev), your-domain.vercel.app (for prod)
AUTH_STRAVA_ID=
AUTH_STRAVA_SECRET=

# Public-safe display name
NEXT_PUBLIC_APP_NAME=whatshouldirunnext
